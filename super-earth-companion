<!DOCTYPE html>
<html lang="it" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Super Earth Companion</title>
  <link rel="preconnect" href="https://api.fontshare.com">
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=cabinet-grotesk@500,700&display=swap" rel="stylesheet">
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <style>
    :root,[data-theme="light"]{
      --font-body:'General Sans',Inter,sans-serif;
      --font-display:'Cabinet Grotesk',Inter,sans-serif;
      --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);
      --text-sm:clamp(.875rem,.8rem + .35vw,1rem);
      --text-base:clamp(1rem,.95rem + .25vw,1.125rem);
      --text-lg:clamp(1.125rem,1rem + .75vw,1.5rem);
      --text-xl:clamp(1.5rem,1.2rem + 1.25vw,2.25rem);
      --space-1:.25rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-5:1.25rem;--space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;
      --color-bg:#f7f6f2;--color-surface:#f9f8f5;--color-surface-2:#fbfbf9;--color-surface-offset:#f3f0ec;--color-border:#d4d1ca;--color-divider:#dcd9d5;
      --color-text:#28251d;--color-text-muted:#6c6a65;--color-text-faint:#9d9a94;--color-text-inverse:#f9f8f4;
      --color-primary:#01696f;--color-primary-hover:#0c4e54;--color-primary-highlight:#cedcd8;--color-success:#437a22;--color-warning:#964219;--color-error:#a12c7b;
      --radius-sm:.375rem;--radius-md:.75rem;--radius-lg:1rem;--radius-full:9999px;
      --shadow-sm:0 1px 2px oklch(0.2 0.01 80 / 0.06);--shadow-md:0 8px 24px oklch(0.2 0.01 80 / 0.10);
      --transition:180ms cubic-bezier(.16,1,.3,1);
    }
    [data-theme="dark"]{
      --color-bg:#171614;--color-surface:#1c1b19;--color-surface-2:#201f1d;--color-surface-offset:#22211f;--color-border:#393836;--color-divider:#262523;
      --color-text:#ece9e1;--color-text-muted:#a5a29b;--color-text-faint:#6d6a64;--color-text-inverse:#2b2a28;
      --color-primary:#4f98a3;--color-primary-hover:#67b3bf;--color-primary-highlight:#313b3b;--color-success:#79b658;--color-warning:#e8af34;--color-error:#d163a7;
      --shadow-sm:0 1px 2px oklch(0 0 0 / 0.25);--shadow-md:0 12px 32px oklch(0 0 0 / 0.35);
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
    body{min-height:100dvh;background:var(--color-bg);color:var(--color-text);font:400 var(--text-base)/1.55 var(--font-body)}
    button,input,select{font:inherit;color:inherit}
    a,button,input{transition:background var(--transition),color var(--transition),border-color var(--transition),transform var(--transition),box-shadow var(--transition)}
    .shell{max-width:1100px;margin:0 auto;padding:calc(env(safe-area-inset-top) + var(--space-4)) var(--space-4) calc(88px + env(safe-area-inset-bottom));display:grid;gap:var(--space-4)}
    .topbar{position:sticky;top:0;z-index:10;display:flex;justify-content:space-between;align-items:center;gap:var(--space-3);padding:var(--space-3) 0;background:linear-gradient(to bottom,var(--color-bg) 75%,transparent)}
    .brand{display:flex;align-items:center;gap:var(--space-3)}
    .logo{width:42px;height:42px;border-radius:14px;background:linear-gradient(145deg,var(--color-primary-highlight),transparent),var(--color-surface);display:grid;place-items:center;border:1px solid color-mix(in oklab,var(--color-text) 12%, transparent);box-shadow:var(--shadow-sm)}
    .logo svg{width:24px;height:24px}
    .brand h1{font:700 var(--text-lg)/1.05 var(--font-display);letter-spacing:-.02em}
    .brand p{font-size:var(--text-xs);color:var(--color-text-muted)}
    .icon-btn{min-width:44px;min-height:44px;border-radius:var(--radius-full);border:1px solid color-mix(in oklab,var(--color-text) 10%, transparent);background:var(--color-surface)}
    .hero,.panel,.list-card,.detail-card,.arsenal-card,.news-card{background:var(--color-surface);border:1px solid color-mix(in oklab,var(--color-text) 10%, transparent);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm)}
    .hero{padding:var(--space-5);display:grid;gap:var(--space-4);background:
      radial-gradient(circle at top right,color-mix(in oklab,var(--color-primary) 18%, transparent),transparent 35%),
      var(--color-surface)}
    .eyebrow{font-size:var(--text-xs);text-transform:uppercase;letter-spacing:.16em;color:var(--color-warning)}
    .hero h2{font:700 var(--text-xl)/1.02 var(--font-display);max-width:14ch;letter-spacing:-.03em}
    .hero p{color:var(--color-text-muted);max-width:55ch}
    .hero-actions,.filters,.chip-row,.stats-grid,.grid{display:flex;flex-wrap:wrap;gap:var(--space-3)}
    .btn{min-height:44px;padding:.8rem 1rem;border-radius:var(--radius-full);border:1px solid transparent;display:inline-flex;align-items:center;justify-content:center;gap:.5rem;text-decoration:none}
    .btn-primary{background:var(--color-primary);color:var(--color-text-inverse)}
    .btn-secondary{background:var(--color-surface-offset);border-color:color-mix(in oklab,var(--color-text) 10%, transparent)}
    .btn:active{transform:translateY(1px)}
    .stats-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr))}
    .stat{padding:var(--space-4);background:var(--color-surface-2);border-radius:var(--radius-md);border:1px solid color-mix(in oklab,var(--color-text) 8%, transparent)}
    .stat-label{font-size:var(--text-xs);color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.12em}
    .stat-value{font:700 var(--text-lg)/1.1 var(--font-display);margin-top:.4rem}
    .section-title{display:flex;justify-content:space-between;align-items:end;gap:var(--space-3);margin:var(--space-2) 0}
    .section-title h3{font:700 var(--text-lg)/1.1 var(--font-display)}
    .section-title p{font-size:var(--text-sm);color:var(--color-text-muted)}
    .grid{display:grid;grid-template-columns:1fr;gap:var(--space-4)}
    .news-card,.arsenal-card,.list-card,.detail-card,.panel{padding:var(--space-4)}
    .news-card header,.arsenal-card header,.detail-card header{display:grid;gap:.35rem;margin-bottom:var(--space-3)}
    .meta{font-size:var(--text-xs);color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.14em}
    .tag,.chip{display:inline-flex;align-items:center;gap:.35rem;padding:.42rem .7rem;border-radius:var(--radius-full);font-size:var(--text-xs);background:var(--color-surface-offset);border:1px solid color-mix(in oklab,var(--color-text) 8%, transparent)}
    .tag.hot{background:color-mix(in oklab,var(--color-warning) 15%, var(--color-surface));color:var(--color-warning)}
    .tag.active{background:color-mix(in oklab,var(--color-primary) 14%, var(--color-surface));color:var(--color-primary)}
    .list{display:grid;gap:var(--space-3)}
    .list-item{padding:var(--space-3);border-radius:var(--radius-md);background:var(--color-surface-2);border:1px solid color-mix(in oklab,var(--color-text) 7%, transparent);display:grid;gap:.35rem}
    .list-item strong{font-weight:600}
    .muted{color:var(--color-text-muted)}
    .search{display:grid;gap:var(--space-3)}
    .search input,.search select{min-height:48px;padding:0 .95rem;background:var(--color-surface-2);border:1px solid color-mix(in oklab,var(--color-text) 10%, transparent);border-radius:var(--radius-md);width:100%}
    .two-col{display:grid;grid-template-columns:1fr;gap:var(--space-4)}
    .bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:12;padding:var(--space-2) var(--space-3) calc(var(--space-2) + env(safe-area-inset-bottom));background:color-mix(in oklab,var(--color-bg) 90%, transparent);backdrop-filter:blur(16px);border-top:1px solid color-mix(in oklab,var(--color-text) 8%, transparent)}
    .bottom-nav nav{max-width:720px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:var(--space-2)}
    .tab-btn{min-height:54px;border-radius:16px;background:transparent;color:var(--color-text-muted);border:1px solid transparent;display:grid;place-items:center;gap:2px;font-size:11px}
    .tab-btn.active{background:var(--color-surface);color:var(--color-text);border-color:color-mix(in oklab,var(--color-text) 9%, transparent);box-shadow:var(--shadow-sm)}
    .tab-btn svg{width:18px;height:18px}
    [data-view]{display:none}
    [data-view].active{display:grid;gap:var(--space-4)}
    .split-row{display:flex;justify-content:space-between;gap:var(--space-4);align-items:center}
    .hr{height:1px;background:var(--color-divider);margin:var(--space-3) 0}
    .empty{padding:var(--space-8) var(--space-4);text-align:center;color:var(--color-text-muted)}
    .footer-note{font-size:var(--text-xs);color:var(--color-text-muted)}
    @media (min-width:768px){
      .shell{padding-left:var(--space-6);padding-right:var(--space-6)}
      .grid{grid-template-columns:1.15fr .85fr}
      .two-col{grid-template-columns:1fr 1fr}
      .stats-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
    }
  </style>
</head>
<body>
  <a class="sr-only" href="#content">Salta al contenuto</a>
  <div class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="logo" aria-label="Super Earth Companion logo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l7 4v5c0 5-3 8-7 11-4-3-7-6-7-11V6l7-4Z"/>
            <path d="M8.5 11.5 12 8l3.5 3.5"/>
            <path d="M12 8v8"/>
          </svg>
        </div>
        <div>
          <h1>Super Earth Companion</h1>
          <p>News di guerra, loadout e intel tattico</p>
        </div>
      </div>
      <button class="icon-btn" id="themeToggle" aria-label="Cambia tema">◐</button>
    </header>

    <main id="content">
      <section data-view="home" class="active"></section>
      <section data-view="news"></section>
      <section data-view="loadouts"></section>
      <section data-view="arsenal"></section>
      <section data-view="profile"></section>
    </main>
  </div>

  <div class="bottom-nav">
    <nav aria-label="Navigazione principale">
      <button class="tab-btn active" data-tab="home"><span>⌂</span><span>Home</span></button>
      <button class="tab-btn" data-tab="news"><span>✦</span><span>News</span></button>
      <button class="tab-btn" data-tab="loadouts"><span>▣</span><span>Loadout</span></button>
      <button class="tab-btn" data-tab="arsenal"><span>⌘</span><span>Arsenale</span></button>
      <button class="tab-btn" data-tab="profile"><span>☉</span><span>Profilo</span></button>
    </nav>
  </div>

<script>
const appState = {
  theme: 'dark',
  selectedFaction: 'Tutte',
  selectedCategory: 'primarie',
  profile: { role: 'Supporto tattico', faction: 'Automaton', difficulty: '7-9', style: 'Controllo e utility' },
  war: {
    majorOrder: {
      title: 'Operazione Martello dell\'Aurora',
      briefing: 'Concentrare la pressione sui mondi industriali del fronte Automaton. Priorità assoluta alla tenuta delle linee di estrazione e alla distruzione degli asset corazzati.'
    },
    dispatches: [
      'Super Terra conferma l\'aumento dei rinforzi sui settori centrali.',
      'Le difese di confine richiedono squadre con capacità anti-armatura elevate.',
      'I comandi regionali raccomandano loadout conservativi sui pianeti ad alta mortalità.'
    ],
    fronts: [
      { planet:'Varylia 5', faction:'Automaton', type:'Difesa', liberation:'42.8%', players:18342, biome:'Highlands', hazards:['Nebbia ionica','Mine'], hot:true },
      { planet:'Fori Prime', faction:'Terminids', type:'Liberazione', liberation:'67.1%', players:25113, biome:'Desert', hazards:['Calore','Spore'], hot:true },
      { planet:'Genesis Prime', faction:'Illuminate', type:'Liberazione', liberation:'18.9%', players:9722, biome:'Ethereal', hazards:['Tempeste psioniche'], hot:false }
    ]
  },
  loadouts: [
    { id:'beginner', nome:'Principiante', difficolta:'Molto facile', fazione:'Tutte', primaria:'Liberator Penetrator AR-23P', secondaria:'Redeemer P-19', granata:'High Explosive G-12', armatura:'Media - Med-Kit', stratagemmi:['Shield Generator Pack','Expendable Anti-Tank EAT','Eagle Airstrike','Machine Gun Sentry'], descrizione:'Build semplice da usare che copre quasi tutte le situazioni. Ideale per imparare il gioco.' },
    { id:'grenadier', nome:'Granatiere', difficolta:'Facile', fazione:'Tutte', primaria:'Scorcher PLAS-1', secondaria:'Grenade Pistol GP-31', granata:'Thermite G-123', armatura:'Media - Engineering Kit', stratagemmi:['Supply Pack','Grenade Launcher GL-21','Eagle Airstrike','Eagle 500kg Bomb'], descrizione:'Build aggressiva ed esplosiva. Richiede buona gestione delle munizioni.' },
    { id:'sniper', nome:'Cecchino', difficolta:'Medio', fazione:'Bot / Illuminate', primaria:'Purifier PLAS-101', secondaria:'Senator P-4', granata:'Stun Grenade G-2', armatura:'Leggera - Siege Ready', stratagemmi:['Jump Pack','Anti-Materiel Rifle APW-1','Orbital Railcannon Strike','Orbital Precision Strike'], descrizione:'Stile di gioco a distanza, preciso e tattico. Eccellente contro bersagli medi e bot.' },
    { id:'spartan', nome:'Spartano', difficolta:'Difficile', fazione:'Tutte', primaria:'Eruptor R-36', secondaria:'Stun Lance CQC-19', granata:'Thermite G-123', armatura:'Pesante - Peak Physique', stratagemmi:['Ballistic Shield Backpack','Expendable Anti-Tank EAT','Orbital Railcannon Strike','Eagle 500kg Bomb'], descrizione:'Build molto caratteristica, difensiva ma aggressiva sui target grossi. Richiede pratica.' }
  ],
  inventory: {
    primarie:[
      { nome:'Liberator Penetrator AR-23P', tier:'A', uso:'Versatile contro fanteria e medi corazzati' },
      { nome:'Scorcher PLAS-1', tier:'S', uso:'Danno esplosivo e controllo bersagli compatti' },
      { nome:'Purifier PLAS-101', tier:'A+', uso:'Precisione e penetrazione su range medio-lungo' },
      { nome:'Eruptor R-36', tier:'A', uso:'Pick tecnico ad alto impatto' }
    ],
    secondarie:[
      { nome:'Redeemer P-19', tier:'A', uso:'Backup ravvicinato ad alta cadenza' },
      { nome:'Senator P-4', tier:'A', uso:'Alta precisione e danno per colpi singoli' },
      { nome:'Grenade Pistol GP-31', tier:'S', uso:'Utility esplosiva su bug hole e gruppi' }
    ],
    supporto:[
      { nome:'Expendable Anti-Tank EAT', tier:'S', uso:'Anti-armatura immediato' },
      { nome:'Grenade Launcher GL-21', tier:'A', uso:'Pulizia ondate e controllo area' },
      { nome:'Anti-Materiel Rifle APW-1', tier:'A', uso:'Precisione su bersagli elitari' }
    ],
    armature:[
      { nome:'Media - Med-Kit', tier:'A', uso:'Sopravvivenza generale' },
      { nome:'Media - Engineering Kit', tier:'S', uso:'Gestione esplosivi e utility' },
      { nome:'Pesante - Peak Physique', tier:'A', uso:'Tenuta e stabilità su front line' }
    ],
    granate:[
      { nome:'High Explosive G-12', tier:'A', uso:'Granata generica affidabile' },
      { nome:'Thermite G-123', tier:'S', uso:'Ottima su bersagli pesanti' },
      { nome:'Stun Grenade G-2', tier:'A', uso:'Controllo e setup tattico' }
    ],
    stratagemmi:[
      { nome:'Eagle Airstrike', tier:'S', uso:'Impatto universale' },
      { nome:'Orbital Precision Strike', tier:'A', uso:'Eliminazione singolo bersaglio' },
      { nome:'Machine Gun Sentry', tier:'A', uso:'Difesa zona e copertura' },
      { nome:'Shield Generator Pack', tier:'A', uso:'Sicurezza e margin of error' }
    ]
  }
};

const tg = window.Telegram?.WebApp;
if (tg) {
  tg.ready();
  tg.expand();
  tg.setHeaderColor('#171614');
  tg.setBackgroundColor('#171614');
}

const views = Object.fromEntries([...document.querySelectorAll('[data-view]')].map(el => [el.dataset.view, el]));
const tabButtons = [...document.querySelectorAll('[data-tab]')];
const themeToggle = document.getElementById('themeToggle');

function escapeHtml(str=''){return str.replace(/[&<>\"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}
function numberIt(v){return new Intl.NumberFormat('it-IT').format(v)}
function tagFaction(f){return `<span class="tag ${/Automaton|Bot/.test(f)?'active':'hot'}">${escapeHtml(f)}</span>`}

function renderHome(){
  const hot = appState.war.fronts.filter(f=>f.hot).slice(0,2);
  views.home.innerHTML = `
    <article class="hero">
      <p class="eyebrow">Canale prioritario di Super Terra</p>
      <h2>${escapeHtml(appState.war.majorOrder.title)}</h2>
      <p>${escapeHtml(appState.war.majorOrder.briefing)}</p>
      <div class="hero-actions">
        <button class="btn btn-primary" data-nav="news">Apri bollettino</button>
        <button class="btn btn-secondary" data-nav="loadouts">Vedi loadout</button>
      </div>
      <div class="stats-grid">
        <div class="stat"><div class="stat-label">Fronti attivi</div><div class="stat-value">${appState.war.fronts.length}</div></div>
        <div class="stat"><div class="stat-label">Pianeti caldi</div><div class="stat-value">${hot.length}</div></div>
        <div class="stat"><div class="stat-label">Dispacci</div><div class="stat-value">${appState.war.dispatches.length}</div></div>
        <div class="stat"><div class="stat-label">Difficoltà profilo</div><div class="stat-value">${escapeHtml(appState.profile.difficulty)}</div></div>
      </div>
    </article>
    <section class="grid">
      <div class="panel">
        <div class="section-title"><h3>Fronti caldi</h3><p>Pianeti con priorità operativa</p></div>
        <div class="list">
          ${hot.map(front => `
            <article class="list-item">
              <div class="split-row"><strong>${escapeHtml(front.planet)}</strong>${tagFaction(front.faction)}</div>
              <div class="muted">${escapeHtml(front.type)} · ${escapeHtml(front.liberation)} · ${numberIt(front.players)} Helldivers</div>
              <div class="chip-row">${front.hazards.map(h=>`<span class="chip">${escapeHtml(h)}</span>`).join('')}</div>
            </article>`).join('')}
        </div>
      </div>
      <div class="panel">
        <div class="section-title"><h3>Build consigliata</h3><p>Per il tuo profilo</p></div>
        ${renderSuggestedLoadoutCard()}
      </div>
    </section>
  `;
}

function renderNews(){
  views.news.innerHTML = `
    <section class="section-title"><h3>News da Super Terra</h3><p>Major Order, fronti e dispacci</p></section>
    <article class="news-card">
      <header>
        <span class="meta">Ordine maggiore attivo</span>
        <h3>${escapeHtml(appState.war.majorOrder.title)}</h3>
        <p class="muted">${escapeHtml(appState.war.majorOrder.briefing)}</p>
      </header>
      <div class="chip-row"><span class="tag active">Operazione live</span><span class="tag">Briefing centrale</span></div>
    </article>
    <section class="two-col">
      <div class="panel">
        <div class="section-title"><h3>Fronti di guerra</h3><p>Live campaign</p></div>
        <div class="list">${appState.war.fronts.map(front=>`
          <article class="list-item">
            <div class="split-row"><strong>${escapeHtml(front.planet)}</strong>${tagFaction(front.faction)}</div>
            <div class="muted">${escapeHtml(front.type)} · ${escapeHtml(front.biome)} · ${escapeHtml(front.liberation)}</div>
            <div class="muted">${numberIt(front.players)} Helldivers attivi</div>
            <div class="chip-row">${front.hazards.map(h=>`<span class="chip">${escapeHtml(h)}</span>`).join('')}</div>
          </article>`).join('')}</div>
      </div>
      <div class="panel">
        <div class="section-title"><h3>Dispacci</h3><p>Canali ufficiali</p></div>
        <div class="list">${appState.war.dispatches.map(item=>`<article class="list-item"><strong>Dispaccio</strong><div class="muted">${escapeHtml(item)}</div></article>`).join('')}</div>
      </div>
    </section>
  `;
}

function pickSuggestedLoadout(){
  const faction = appState.profile.faction;
  return appState.loadouts.find(l => l.fazione.includes('Tutte') || l.fazione.includes(faction) || (faction === 'Automaton' && l.fazione.includes('Bot'))) || appState.loadouts[0];
}

function renderSuggestedLoadoutCard(){
  const l = pickSuggestedLoadout();
  return `
    <article class="detail-card">
      <header>
        <span class="meta">Raccomandazione dinamica</span>
        <h3>${escapeHtml(l.nome)}</h3>
        <p class="muted">${escapeHtml(l.descrizione)}</p>
      </header>
      <div class="chip-row">
        <span class="chip">${escapeHtml(l.difficolta)}</span>
        <span class="chip">${escapeHtml(l.fazione)}</span>
      </div>
      <div class="hr"></div>
      <div class="list">
        <div class="list-item"><strong>Primaria</strong><div class="muted">${escapeHtml(l.primaria)}</div></div>
        <div class="list-item"><strong>Secondaria</strong><div class="muted">${escapeHtml(l.secondaria)}</div></div>
        <div class="list-item"><strong>Armatura</strong><div class="muted">${escapeHtml(l.armatura)}</div></div>
      </div>
    </article>`;
}

function renderLoadouts(){
  views.loadouts.innerHTML = `
    <section class="section-title"><h3>Loadout operativi</h3><p>Build curate e pronte</p></section>
    <div class="list">${appState.loadouts.map(l=>`
      <article class="arsenal-card">
        <header>
          <span class="meta">${escapeHtml(l.difficolta)} · ${escapeHtml(l.fazione)}</span>
          <h3>${escapeHtml(l.nome)}</h3>
          <p class="muted">${escapeHtml(l.descrizione)}</p>
        </header>
        <div class="two-col">
          <div class="list">
            <div class="list-item"><strong>Primaria</strong><div class="muted">${escapeHtml(l.primaria)}</div></div>
            <div class="list-item"><strong>Secondaria</strong><div class="muted">${escapeHtml(l.secondaria)}</div></div>
            <div class="list-item"><strong>Granata</strong><div class="muted">${escapeHtml(l.granata)}</div></div>
            <div class="list-item"><strong>Armatura</strong><div class="muted">${escapeHtml(l.armatura)}</div></div>
          </div>
          <div class="list">
            ${l.stratagemmi.map(s=>`<div class="list-item"><strong>Stratagemma</strong><div class="muted">${escapeHtml(s)}</div></div>`).join('')}
          </div>
        </div>
        <div class="hero-actions" style="margin-top:var(--space-3)">
          <button class="btn btn-primary" data-copy="${l.id}">Invia al bot</button>
          <button class="btn btn-secondary" data-profile="${l.id}">Usa per il profilo</button>
        </div>
      </article>`).join('')}</div>
  `;
}

function renderArsenal(){
  const categories = Object.keys(appState.inventory);
  const items = appState.inventory[appState.selectedCategory] || [];
  views.arsenal.innerHTML = `
    <section class="section-title"><h3>Arsenale</h3><p>Ricerca rapida equipaggiamento</p></section>
    <article class="panel search">
      <label for="category">Categoria</label>
      <select id="category">${categories.map(c=>`<option value="${c}" ${c===appState.selectedCategory?'selected':''}>${c}</option>`).join('')}</select>
    </article>
    <div class="list">
      ${items.map(item=>`<article class="list-card"><div class="split-row"><strong>${escapeHtml(item.nome)}</strong><span class="tag ${item.tier.startsWith('S')?'active':''}">Tier ${escapeHtml(item.tier)}</span></div><div class="muted">${escapeHtml(item.uso)}</div></article>`).join('')}
    </div>
  `;
}

function renderProfile(){
  views.profile.innerHTML = `
    <section class="section-title"><h3>Profilo Helldiver</h3><p>Preferenze e sincronizzazione bot</p></section>
    <article class="panel search">
      <label for="role">Ruolo</label>
      <input id="role" value="${escapeHtml(appState.profile.role)}" />
      <label for="faction">Fazione preferita</label>
      <select id="faction">
        ${['Automaton','Terminids','Illuminate','Tutte'].map(f=>`<option value="${f}" ${f===appState.profile.faction?'selected':''}>${f}</option>`).join('')}
      </select>
      <label for="difficulty">Fascia difficoltà</label>
      <input id="difficulty" value="${escapeHtml(appState.profile.difficulty)}" />
      <label for="style">Stile di gioco</label>
      <input id="style" value="${escapeHtml(appState.profile.style)}" />
      <div class="hero-actions">
        <button class="btn btn-primary" id="saveProfile">Salva nel bot</button>
        <button class="btn btn-secondary" id="sendSummary">Invia riepilogo</button>
      </div>
      <p class="footer-note">In produzione, questi dati possono essere inviati al bot tramite sendData e salvati lato server.</p>
    </article>
    <div class="panel">
      <div class="section-title"><h3>Build suggerita</h3><p>Basata sul profilo corrente</p></div>
      ${renderSuggestedLoadoutCard()}
    </div>
  `;
}

function switchTab(tab){
  tabButtons.forEach(btn=>btn.classList.toggle('active', btn.dataset.tab === tab));
  Object.values(views).forEach(v=>v.classList.remove('active'));
  views[tab].classList.add('active');
}

function applyTheme(theme){
  appState.theme = theme;
  document.documentElement.setAttribute('data-theme', theme);
  if (tg) {
    tg.setHeaderColor(theme === 'dark' ? '#171614' : '#f7f6f2');
    tg.setBackgroundColor(theme === 'dark' ? '#171614' : '#f7f6f2');
  }
}

function sendToBot(payload){
  const data = JSON.stringify(payload);
  if (tg?.sendData) tg.sendData(data);
  else alert('Payload demo inviato: ' + data);
}

function rerender(){renderHome();renderNews();renderLoadouts();renderArsenal();renderProfile();bindDynamicEvents();}

function bindDynamicEvents(){
  document.querySelectorAll('[data-nav]').forEach(btn => btn.onclick = () => switchTab(btn.dataset.nav));
  document.querySelectorAll('[data-copy]').forEach(btn => btn.onclick = () => {
    const loadout = appState.loadouts.find(l => l.id === btn.dataset.copy);
    sendToBot({ type:'loadout_selected', loadout });
    if (tg?.HapticFeedback) tg.HapticFeedback.notificationOccurred('success');
  });
  document.querySelectorAll('[data-profile]').forEach(btn => btn.onclick = () => {
    const loadout = appState.loadouts.find(l => l.id === btn.dataset.profile);
    appState.profile.role = loadout.nome;
    rerender();
  });
  const category = document.getElementById('category');
  if (category) category.onchange = e => { appState.selectedCategory = e.target.value; renderArsenal(); bindDynamicEvents(); };
  const saveProfile = document.getElementById('saveProfile');
  if (saveProfile) saveProfile.onclick = () => {
    appState.profile = {
      role: document.getElementById('role').value,
      faction: document.getElementById('faction').value,
      difficulty: document.getElementById('difficulty').value,
      style: document.getElementById('style').value
    };
    sendToBot({ type:'profile_save', profile: appState.profile });
    rerender();
  };
  const sendSummary = document.getElementById('sendSummary');
  if (sendSummary) sendSummary.onclick = () => sendToBot({ type:'profile_summary', profile: appState.profile, suggestedLoadout: pickSuggestedLoadout() });
}

tabButtons.forEach(btn => btn.addEventListener('click', () => switchTab(btn.dataset.tab)));
themeToggle.addEventListener('click', () => applyTheme(appState.theme === 'dark' ? 'light' : 'dark'));
applyTheme(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
rerender();
</script>
</body>
</html>
